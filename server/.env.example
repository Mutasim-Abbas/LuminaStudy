# Copy this file to `.env` and fill in your values. `.env` is git-ignored —
# your real key never gets committed or sent to the browser.

# --- Option A (recommended right now): Groq — free, no billing, 2-min signup ---
# Get a key at https://console.groq.com/keys (starts with gsk_).
# NOTE: Google's new "AQ." Gemini keys currently FAIL auth (known Google bug,
# June 2026+), which is why Groq is the reliable choice today.
# If this key is set, it is used INSTEAD of Gemini.
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# --- Option B: Gemini (works only with old AIza-format keys) ---
GEMINI_API_KEY=

# Which Gemini model to use. Change if your key targets a different one.
GEMINI_MODEL=gemini-2.0-flash

# Secret used to sign login sessions. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Where the frontend runs (locks CORS to this origin).
CORS_ORIGIN=http://localhost:5180

# Server port.
PORT=3001

NODE_ENV=development
