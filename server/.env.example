# Copy this file to `.env` and fill in your values. `.env` is git-ignored —
# your real key is never committed and never reaches the browser.

# --- AI provider: Groq (free tier available) ---
# Get a key at https://console.groq.com/keys (starts with gsk_).
GROQ_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# Secret used to sign login sessions. Required in production (32+ chars);
# in development an ephemeral secret is generated if this is empty.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# --- Password-reset email (optional) ---
# Without a key the server still issues valid reset links — it prints them to
# the console instead of emailing them, so local development needs no signup.
# Production refuses to fall back this way, since a silently unsent reset email
# would strand real users.
# Get a key at https://resend.com (free tier: 100 emails/day, starts with re_).
RESEND_API_KEY=
# Resend's shared testing sender works immediately but can only deliver to your
# own signup address. Swap in an address on a domain you've verified to email
# anyone else.
MAIL_FROM=Lumina Study <onboarding@resend.dev>

# Base URL the emailed reset link points at — must be where the app is served.
APP_URL=http://localhost:3001

# Where the frontend dev server runs (locks CORS to this origin).
CORS_ORIGIN=http://localhost:5174

# Server port.
PORT=3001

NODE_ENV=development
