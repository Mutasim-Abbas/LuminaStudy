{
  "name": "lumina-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Lumina Study backend — secure AI proxy, SQLite database, and auth.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check-key": "node scripts/check-key.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^10.1.0",
    "@google/genai": "^2.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "svg-captcha": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
